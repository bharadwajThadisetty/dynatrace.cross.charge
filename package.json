{
  "name": "cross-charge",
  "version": "0.0.0",
  "description": "Provides workflow actions for identifying DPS cost per entity/tag",
  "scripts": {
    "start": "dt-app dev",
    "build": "dt-app build",
    "deploy": "dt-app deploy",
    "create:action": "dt-app action create",
    "create:function": "dt-app function create",
    "help": "dt-app help",
    "info": "dt-app info",
    "lint": "eslint .",
    "lint:check-performance": "DEBUG=eslint:cli-engine TIMING=1 eslint .",
    "lint:commit-all": "commitlint --to HEAD",
    "lint:fix": "eslint . --fix",
    "lint:source": "eslint . --report-unused-disable-directives",
    "typecheck:app": "tsc --pretty --noEmit -p ui/tsconfig.json",
    "uninstall": "dt-app uninstall",
    "update": "dt-app update"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@dynatrace-sdk/app-environment": "^1.1.4",
    "@dynatrace-sdk/automation-action-utils": "^0.34.0",
    "@dynatrace-sdk/client-app-settings-v2": "^1.1.3",
    "@dynatrace-sdk/client-automation": "^6.0.0",
    "@dynatrace-sdk/client-classic-environment-v2": "^5.2.3",
    "@dynatrace-sdk/client-query": "^1.21.2",
    "@dynatrace-sdk/error-handlers": "^1.3.1",
    "@dynatrace-sdk/navigation": "^2.2.0",
    "@dynatrace-sdk/react-hooks": "^1.6.0",
    "@dynatrace-sdk/units": "^1.5.0",
    "@dynatrace-sdk/user-preferences": "^1.1.3",
    "@dynatrace/automation-action-components": "^1.0.2",
    "@dynatrace/strato-components": "^3.0.1",
    "@dynatrace/strato-components-preview": "^3.0.1",
    "@dynatrace/strato-design-tokens": "^1.3.1",
    "@dynatrace/strato-icons": "^2.0.0",
    "esbuild": "^0.28.0",
    "lodash-es": "^4.18.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.0.0",
    "react-intl": "7.1.14",
    "react-router-dom": "^7.12.0",
    "styled-components": "^6.1.19",
    "typescript": "^5.9.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@dynatrace-sdk/dt-app-plugin-client-app-settings-v2": "^0.4.0",
    "@eslint/js": "^9.37.0",
    "@microsoft/eslint-plugin-sdl": "^1.1.0",
    "@testing-library/react": "^14.2.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/jest": "^29.5.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.7.0",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.5",
    "dt-app": "1.8.1",
    "eslint": "^9.37.0",
    "eslint-plugin-n": "17.23.1",
    "eslint-plugin-no-secrets": "^2.2.1",
    "eslint-plugin-no-unsanitized": "^4.1.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^6.1.1",
    "eslint-plugin-security": "^3.0.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0"
  }
